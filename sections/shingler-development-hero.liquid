{{ 'section-shingler-development-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_image = section.settings.image
  if hero_image == blank and collection.image != blank
    assign hero_image = collection.image
  endif
  assign hero_title = section.settings.heading
  if hero_title == blank and collection != blank
    assign hero_title = collection.title
  endif
  assign hero_text = section.settings.text
  if hero_text == blank and collection.description != blank
    assign hero_text = collection.description
  endif
-%}

<div class="shingler-development-hero color-scheme-3">
  {%- if hero_image != blank -%}
    <div class="shingler-development-hero__media">
      {{
        hero_image
        | image_url: width: 2000
        | image_tag: loading: 'eager', sizes: '100vw', fetchpriority: 'high'
      }}
    </div>
  {%- endif -%}
  <div class="shingler-development-hero__overlay"></div>
  <div class="page-width shingler-development-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="shingler-development-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if hero_title != blank -%}
      <h1 class="shingler-development-hero__heading h1">{{ hero_title | escape }}</h1>
    {%- endif -%}
    {%- if hero_text != blank -%}
      <p class="shingler-development-hero__text">{{ hero_text | escape }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Development hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Development"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Defaults to collection title"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "info": "Defaults to collection description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Defaults to collection image"
    }
  ],
  "presets": [
    {
      "name": "Development hero"
    }
  ]
}
{% endschema %}
