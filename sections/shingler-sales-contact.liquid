{{ 'section-shingler-sales-contact.css' | asset_url | stylesheet_tag }}
{{ 'component-shingler-cta.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width shingler-sales-contact">
    <div>
      {%- if section.settings.heading != blank -%}
        <h2 class="shingler-sales-contact__heading h2">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="shingler-sales-contact__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}
    </div>
    <div class="shingler-sales-contact__details">
      {%- if section.settings.contact_intro != blank -%}
        <p class="shingler-sales-contact__text">{{ section.settings.contact_intro | escape }}</p>
      {%- endif -%}
      {%- if section.settings.contact_name != blank -%}
        <p class="shingler-sales-contact__text"><strong>{{ section.settings.contact_name | escape }}</strong></p>
      {%- endif -%}
      {%- if section.settings.contact_email != blank -%}
        <p class="shingler-sales-contact__text">
          <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email | escape }}</a>
        </p>
      {%- endif -%}
      {%- if section.settings.contact_phone != blank -%}
        <p class="shingler-sales-contact__text">
          <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone | escape }}</a>
        </p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        {% render 'shingler-cta', label: section.settings.button_label, url: section.settings.button_link, style: 'primary' %}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sales contact",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sales Suite"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Coming soon!"
    },
    {
      "type": "textarea",
      "id": "contact_intro",
      "label": "Contact intro",
      "default": "Register your interest now by contacting our Sales Negotiator:"
    },
    {
      "type": "text",
      "id": "contact_name",
      "label": "Contact name"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact phone"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get in touch"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Sales contact"
    }
  ]
}
{% endschema %}
